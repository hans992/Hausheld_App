# Database (PostgreSQL + PostGIS)
# Local:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hausheld
#
# Supabase — use .env only, never commit real password.
# Direct (db.xxx.supabase.co) is NOT IPv4-compatible. Use Session pooler for IPv4:
#   Host: aws-0-eu-central-1.pooler.supabase.com   Port: 5432   User: postgres.PROJECT_REF
#   DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Transaction pooler (port 6543) does not support IPv4. See backend/SUPABASE.md
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hausheld

# App
ENV=development
DEBUG=true

# Auth (Phase 2): JWT for dev or Supabase
JWT_SECRET=change-me-in-production-dev-only
AUTH_DEV_MODE=true
# Optional production: Supabase
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_JWT_SECRET=your-project-jwt-secret

# Phase 6: GDPR – encrypt health data (Fernet key, generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# ENCRYPTION_KEY=your-base64-fernet-key

# Production: use AWS Frankfurt (eu-central-1) for data residency
# DATABASE_URL=postgresql+asyncpg://...@xxx.eu-central-1.rds.amazonaws.com:5432/hausheld
